# Docker Compose environment variables
# Copy to .env and fill in values before running docker-compose up

NODE_ENV=production

# PostgreSQL
POSTGRES_USER=dental
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=dental_db

# Redis
REDIS_PASSWORD=change_me_strong_password

# JWT — MUST set a strong random secret in production
JWT_SECRET=change_me_to_a_64_char_random_string
JWT_EXPIRES_IN=1d

# CORS
CORS_ORIGIN=http://localhost:3001

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# SMS (MSG91)
SMS_API_KEY=
SMS_SENDER_ID=DENTAL
SMS_ENTITY_ID=
SMS_DEFAULT_DLT_TEMPLATE_ID=
SMS_DLT_TEMPLATE_BODY=

# Sentry
SENTRY_BACKEND_DSN=
SENTRY_FRONTEND_DSN=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Logging
LOG_LEVEL=info

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
