// --- Consent Forms -----------------------------------------------
//
// `consent_templates`: per-clinic library of consent form templates.
// Seeded with 12 system defaults (extraction, RCT, implant, etc.) on first
// access. Admins can replace/override any default and add new templates,
// optionally translated by AI into hi/ta/te/kn/ml/mr/bn/gu/pa, etc.
//
// `patient_consents`: instances generated for a specific patient. Carries
// either an uploaded scanned signed copy (`signed_pdf_key` from S3) or a
// fully digital signature (also rendered to PDF and stored at the same key).
// Both flows are gated on `status` transitioning pending ? signed.
model ConsentTemplate {
  id         String   @id @default(uuid()) @db.Uuid
  clinic_id  String   @db.Uuid
  // Stable form code, e.g. "extraction", "endodontic", "implant".
  // Combined with language for uniqueness; lets the same form exist in
  // multiple languages for one clinic.
  code       String   @db.VarChar(50)
  language   String   @default("en") @db.VarChar(5)
  title      String   @db.VarChar(255)
  // Structured body: { sections: [{ heading, paragraphs[]?, bullets[]? }],
  // risks[]?, consent_statement, signature_lines[] }. Rendered to PDF on
  // demand; AI generation populates this directly so admins can edit.
  body       Json
  // Bumped each time the body changes � printed on the PDF footer so
  // historical patient_consents can identify the wording they signed.
  version    Int      @default(1)
  is_default Boolean  @default(false)
  is_active  Boolean  @default(true)
  // null when the row was AI-generated or seeded; otherwise the staff
  // member who saved this version.
  created_by String?  @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinic           Clinic           @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  creator          User?            @relation("ConsentTemplateCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  patient_consents PatientConsent[]

  @@unique([clinic_id, code, language])
  @@index([clinic_id])
  @@index([clinic_id, is_active])
  @@map("consent_templates")
}

model PatientConsent {
  id             String  @id @default(uuid()) @db.Uuid
  clinic_id      String  @db.Uuid
  branch_id      String  @db.Uuid
  patient_id     String  @db.Uuid
  template_id    String  @db.Uuid
  // Optional links so the consent shows up alongside the related work
  // (e.g. on the treatment timeline as "Consent on file").
  treatment_id   String? @db.Uuid
  appointment_id String? @db.Uuid

  // pending ? signed ? archived. "cancelled" used when staff abandon a
  // generated form before signature.
  status           String @default("pending") @db.VarChar(20)
  // Which template version was used at generation time, so legacy PDFs can
  // be reproduced even after the template is updated.
  template_version Int    @default(1)
  language         String @default("en") @db.VarChar(5)

  // Pre-filled but unsigned PDF, generated at create time.
  generated_pdf_key  String?   @db.VarChar(500)
  // Final signed PDF � for digital signatures we re-render the PDF with
  // the signature image embedded; for upload-back we store the scanned
  // copy as-is (PDF/JPG/PNG converted to PDF on the fly).
  signed_pdf_key     String?   @db.VarChar(500)
  signature_method   String?   @db.VarChar(20) // 'digital' | 'upload'
  signed_by_name     String?   @db.VarChar(255)
  signed_at          DateTime?
  signed_by_staff_id String?   @db.Uuid // staff who witnessed/captured the signature
  witness_staff_id   String?   @db.Uuid // optional second witness

  // ── Remote-link signing (patient signs on their own phone) ──
  // 'in_clinic_digital' | 'paper_upload' | 'remote_link'
  signed_via              String?   @db.VarChar(30)
  signing_token_hash      String?   @db.VarChar(128) // SHA-256 of one-time link token
  signing_token_expires_at DateTime?
  signing_link_sent_at    DateTime?
  signing_link_sent_to    String?   @db.VarChar(50) // phone/email the link went to
  otp_code_hash           String?   @db.VarChar(128) // SHA-256 of current OTP
  otp_expires_at          DateTime?
  otp_verified_at         DateTime?
  otp_attempts            Int       @default(0)
  signed_ip               String?   @db.VarChar(64)
  signed_user_agent       String?   @db.VarChar(500)

  notes      String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinic      Clinic          @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch      Branch          @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  patient     Patient         @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  template    ConsentTemplate @relation(fields: [template_id], references: [id], onDelete: Restrict)
  treatment   Treatment?      @relation(fields: [treatment_id], references: [id], onDelete: SetNull)
  appointment Appointment?    @relation(fields: [appointment_id], references: [id], onDelete: SetNull)
  signed_by   User?           @relation("ConsentSignedByStaff", fields: [signed_by_staff_id], references: [id], onDelete: SetNull)
  witness     User?           @relation("ConsentWitnessStaff", fields: [witness_staff_id], references: [id], onDelete: SetNull)

  @@index([clinic_id])
  @@index([clinic_id, patient_id])
  @@index([clinic_id, status])
  @@index([template_id])
  @@index([treatment_id])
  @@index([signing_token_hash])
  @@map("patient_consents")
}
