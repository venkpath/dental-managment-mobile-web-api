// ─── Platform billing: SaaS invoices we issue to clinics for their
//     subscription payments. Separate from the patient-side `Invoice` model
//     which tracks treatment billing inside each clinic. ───────────────────

/// One row per successful (or refunded) Razorpay charge against a clinic's
/// subscription. The PDF is rendered on-demand from this row using the
/// platform billing entity (Smart Dental Desk / Yeshika Enterprises) as the
/// supplier and the clinic as the bill-to.
model PlatformInvoice {
  id             String @id @default(uuid()) @db.Uuid
  clinic_id      String @db.Uuid
  invoice_number String @unique @db.VarChar(50)

  // Plan + period covered by this charge
  plan_id       String?  @db.Uuid
  plan_name     String   @db.VarChar(100)
  billing_cycle String   @db.VarChar(10) // monthly | yearly
  period_start  DateTime
  period_end    DateTime

  // Money. Plan price is treated as INCLUSIVE of GST: subtotal is reverse-
  // computed (total / (1 + tax_rate/100)), then tax_amount = total - subtotal.
  subtotal     Decimal @db.Decimal(12, 2)
  tax_rate     Decimal @default(18) @db.Decimal(5, 2)
  tax_amount   Decimal @db.Decimal(12, 2)
  total_amount Decimal @db.Decimal(12, 2)
  currency     String  @default("INR") @db.VarChar(10)

  // GST split — populated when the bill-to is intra-state (Karnataka),
  // otherwise igst_amount carries the full tax (inter-state IGST treatment).
  cgst_amount Decimal @default(0) @db.Decimal(12, 2)
  sgst_amount Decimal @default(0) @db.Decimal(12, 2)
  igst_amount Decimal @default(0) @db.Decimal(12, 2)

  // Snapshot of bill-to at issue time so historical PDFs stay correct even
  // if the clinic later edits its profile.
  bill_to_name    String  @db.VarChar(255)
  bill_to_email   String  @db.VarChar(255)
  bill_to_phone   String? @db.VarChar(50)
  bill_to_address String? @db.VarChar(500)
  bill_to_city    String? @db.VarChar(100)
  bill_to_state   String? @db.VarChar(100)
  bill_to_pincode String? @db.VarChar(10)
  bill_to_gstin   String? @db.VarChar(20) // optional: clinic's GSTIN if they provided one

  // Razorpay refs
  razorpay_payment_id      String? @db.VarChar(100)
  razorpay_subscription_id String? @db.VarChar(100)

  // Lifecycle
  status     String  @default("paid") @db.VarChar(20) // paid | failed | refunded
  pdf_s3_key String? @db.VarChar(500) // S3 key once PDF has been rendered + uploaded

  // Delivery tracking (we send via WhatsApp + Email)
  delivery_status  String    @default("pending") @db.VarChar(30) // pending | sent | partial | failed
  whatsapp_sent_at DateTime?
  whatsapp_error   String?   @db.Text
  email_sent_at    DateTime?
  email_error      String?   @db.Text

  issued_at  DateTime @default(now())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  plan   Plan?  @relation(fields: [plan_id], references: [id], onDelete: SetNull)

  @@unique([razorpay_payment_id])
  @@index([clinic_id])
  @@index([clinic_id, issued_at])
  @@index([status])
  @@index([razorpay_subscription_id])
  @@map("platform_invoices")
}

