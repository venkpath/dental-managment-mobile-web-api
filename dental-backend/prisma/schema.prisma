// ─── Clinical Workflow: Visit / Examination / Treatment Planning ───
// Represents a single clinical consultation: chief complaint → exam findings →
// diagnosis → treatment plan. Created when a patient is seen by a dentist
// (optionally linked to a scheduled appointment, or walk-in).

model ClinicalVisit {
  id             String  @id @default(uuid()) @db.Uuid
  clinic_id      String  @db.Uuid
  branch_id      String  @db.Uuid
  patient_id     String  @db.Uuid
  dentist_id     String  @db.Uuid
  appointment_id String? @db.Uuid

  // Step 1 — History & Chief Complaint
  chief_complaint            String? @db.Text
  history_of_present_illness String? @db.Text
  past_dental_history        String? @db.Text
  medical_history_notes      String? @db.Text

  // Step 2 — Clinical Examination
  examination_notes String? @db.Text
  vital_signs       Json?

  // Step 3 — Assessment (SOAP structure — AI generated or manual)
  diagnosis_summary String? @db.Text
  soap_notes        Json?
  review_after_date DateTime?

  // Workflow lifecycle
  status       String    @default("in_progress") @db.VarChar(20) // in_progress | finalized | cancelled
  finalized_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinic      Clinic       @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch      Branch       @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  patient     Patient      @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  dentist     User         @relation("VisitDentist", fields: [dentist_id], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointment_id], references: [id], onDelete: SetNull)

  tooth_conditions PatientToothCondition[]
  treatments       Treatment[]
  treatment_plans  TreatmentPlan[]
  prescriptions    Prescription[]

  @@index([clinic_id])
  @@index([branch_id])
  @@index([patient_id])
  @@index([dentist_id])
  @@index([appointment_id])
  @@index([patient_id, created_at])
  @@map("clinical_visits")
}

model TreatmentPlan {
  id                String  @id @default(uuid()) @db.Uuid
  clinic_id         String  @db.Uuid
  branch_id         String  @db.Uuid
  patient_id        String  @db.Uuid
  dentist_id        String  @db.Uuid
  clinical_visit_id String? @db.Uuid

  title                String    @db.VarChar(255)
  notes                String?   @db.Text
  total_estimated_cost Decimal   @default(0) @db.Decimal(10, 2)
  status               String    @default("proposed") @db.VarChar(20) // proposed | accepted | in_progress | completed | cancelled
  accepted_at          DateTime?
  completed_at         DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinic         Clinic         @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch         Branch         @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  patient        Patient        @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  dentist        User           @relation("PlanDentist", fields: [dentist_id], references: [id], onDelete: Cascade)
  clinical_visit ClinicalVisit? @relation(fields: [clinical_visit_id], references: [id], onDelete: SetNull)

  items      TreatmentPlanItem[]
  treatments Treatment[]

  @@index([clinic_id])
  @@index([branch_id])
  @@index([patient_id])
  @@index([dentist_id])
  @@index([clinical_visit_id])
  @@index([status])
  @@map("treatment_plans")
}

model TreatmentPlanItem {
  id             String  @id @default(uuid()) @db.Uuid
  plan_id        String  @db.Uuid
  tooth_number   String? @db.VarChar(100)
  procedure      String  @db.VarChar(500)
  diagnosis      String? @db.VarChar(500)
  estimated_cost Decimal @default(0) @db.Decimal(10, 2)
  urgency        String? @db.VarChar(20) // immediate | high | medium | low
  phase          Int?    @default(1)
  sequence       Int?    @default(1)
  status         String  @default("proposed") @db.VarChar(20) // proposed | accepted | declined | converted
  notes          String? @db.Text
  treatment_id   String? @db.Uuid

  plan      TreatmentPlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  treatment Treatment?    @relation(fields: [treatment_id], references: [id], onDelete: SetNull)

  @@index([plan_id])
  @@index([treatment_id])
  @@map("treatment_plan_items")
}

model DemoRequest {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(200)
  email      String   @db.VarChar(255)
  phone      String   @db.VarChar(20)
  clinic_name String? @db.VarChar(255)
  chairs     String?  @db.VarChar(10)
  status     String   @default("pending") @db.VarChar(20) // pending | contacted | scheduled | completed | cancelled
  notes      String?  @db.Text
  source     String   @default("website") @db.VarChar(50) // website | landing_page | referral
  scheduled_at DateTime?
  meeting_link String? @db.VarChar(500)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@index([created_at])
  @@map("demo_requests")
}
