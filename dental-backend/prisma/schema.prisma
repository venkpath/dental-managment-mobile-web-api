// ─── Communication & Patient Engagement (Phase 3) ───

model MessageTemplate {
  id                       String   @id @default(uuid()) @db.Uuid
  clinic_id                String?  @db.Uuid // null = system template
  channel                  String   @db.VarChar(20) // email | sms | whatsapp | all
  category                 String   @db.VarChar(30) // reminder | greeting | campaign | transactional | follow_up | referral
  template_name            String   @db.VarChar(255)
  subject                  String?  @db.VarChar(500) // header for WhatsApp / subject for email
  footer                   String?  @db.VarChar(60) // WhatsApp footer text
  body                     String   @db.Text
  variables                Json? // list of supported variables
  language                 String   @default("en") @db.VarChar(5)
  is_active                Boolean  @default(true)
  dlt_template_id          String?  @db.VarChar(100) // SMS DLT compliance
  whatsapp_template_status String?  @db.VarChar(20) // draft | submitted | approved | rejected
  meta_template_id         String?  @db.VarChar(100) // Meta Graph API template ID (for delete/edit)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  clinic                 Clinic?                @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  communication_messages CommunicationMessage[]
  campaigns              Campaign[]
  automation_rules       AutomationRule[]
  clinic_events          ClinicEvent[]

  @@index([clinic_id])
  @@index([channel])
  @@index([category])
  @@index([clinic_id, channel, category])
  @@map("message_templates")
}

model CommunicationMessage {
  id            String    @id @default(uuid()) @db.Uuid
  clinic_id     String    @db.Uuid
  patient_id    String?   @db.Uuid // nullable for broadcast
  template_id   String?   @db.Uuid
  channel       String    @db.VarChar(20) // email | sms | whatsapp | in_app
  category      String    @default("transactional") @db.VarChar(20) // transactional | promotional
  subject       String?   @db.VarChar(500)
  body          String    @db.Text
  recipient     String    @db.VarChar(255) // phone/email
  status        String    @default("queued") @db.VarChar(20) // queued | sent | delivered | read | failed | skipped
  direction     String    @default("outbound") @db.VarChar(10) // outbound | inbound
  skip_reason   String?   @db.VarChar(255) // if skipped: preference_disabled, dnd_hours, dedup, etc.
  wa_message_id String?   @db.VarChar(255) // Meta WhatsApp message ID (wamid.xxx)
  scheduled_at  DateTime?
  sent_at       DateTime?
  metadata      Json? // extra context: campaign_id, appointment_id, etc.
  created_at    DateTime  @default(now())

  clinic   Clinic             @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  patient  Patient?           @relation(fields: [patient_id], references: [id], onDelete: SetNull)
  template MessageTemplate?   @relation(fields: [template_id], references: [id], onDelete: SetNull)
  logs     CommunicationLog[]

  @@index([clinic_id])
  @@index([patient_id])
  @@index([template_id])
  @@index([channel])
  @@index([status])
  @@index([clinic_id, channel, status])
  @@index([scheduled_at])
  @@index([created_at])
  @@index([patient_id, template_id, channel, created_at]) // deduplication query
  @@index([clinic_id, channel, recipient, created_at]) // inbox conversation query
  @@index([wa_message_id]) // webhook status update lookup
  @@map("communication_messages")
}

model PlatformMessage {
  id            String    @id @default(uuid()) @db.Uuid
  direction     String    @db.VarChar(10) // outbound | inbound
  channel       String    @default("whatsapp") @db.VarChar(20) // whatsapp (extensible)
  from_phone    String    @db.VarChar(50) // platform number for outbound, sender for inbound
  to_phone      String    @db.VarChar(50) // recipient for outbound, platform number for inbound
  contact_phone String    @db.VarChar(50) // the OTHER party's phone (for conversation grouping)
  contact_name  String?   @db.VarChar(255) // optional display name
  body          String    @db.Text
  message_type  String    @default("text") @db.VarChar(30) // text | template | image | button | interactive | document | audio | location
  status        String    @default("sent") @db.VarChar(20) // sent | delivered | read | failed
  wa_message_id String?   @db.VarChar(255) // Meta wamid
  template_name String?   @db.VarChar(255) // for outbound template sends
  metadata      Json?
  sent_at       DateTime?
  created_at    DateTime  @default(now())

  @@index([contact_phone])
  @@index([direction])
  @@index([status])
  @@index([wa_message_id])
  @@index([created_at])
  @@index([contact_phone, created_at])
  @@map("platform_messages")
}

model CommunicationLog {
  id                  String    @id @default(uuid()) @db.Uuid
  message_id          String    @db.Uuid
  channel             String    @db.VarChar(20)
  provider            String    @db.VarChar(50) // mailtrap, gmail, msg91, gupshup, etc.
  provider_message_id String?   @db.VarChar(255) // external reference
  status              String    @db.VarChar(20) // sent | delivered | read | failed | bounced
