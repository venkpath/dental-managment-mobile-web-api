generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String    @db.VarChar(255)
  email               String    @db.VarChar(255)
  phone               String?   @db.VarChar(50)
  address             String?   @db.VarChar(500)
  city                String?   @db.VarChar(100)
  state               String?   @db.VarChar(100)
  country             String?   @db.VarChar(100)
  pincode             String?   @db.VarChar(10)
  plan_id             String?   @db.Uuid
  subscription_status String    @default("trial") @db.VarChar(20)
  subscription_id     String?   @db.VarChar(100)
  trial_ends_at       DateTime?
  is_complimentary    Boolean   @default(false)
  logo_url            String?   @db.Text
  ai_usage_count      Int       @default(0)
  ai_quota_override   Int? // per-clinic AI quota override (null = use global/plan default)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  plan                   Plan?                        @relation(fields: [plan_id], references: [id], onDelete: SetNull)
  users                  User[]
  branches               Branch[]
  patients               Patient[]
  appointments           Appointment[]
  treatments             Treatment[]
  prescriptions          Prescription[]
  invoices               Invoice[]
  inventory_items        InventoryItem[]
  attachments            Attachment[]
  tooth_conditions       PatientToothCondition[]
  notifications          Notification[]
  communication_messages CommunicationMessage[]
  message_templates      MessageTemplate[]
  communication_settings ClinicCommunicationSettings?
  campaigns              Campaign[]
  automation_rules       AutomationRule[]
  clinic_events          ClinicEvent[]
  patient_feedback       PatientFeedback[]
  referral_codes         PatientReferralCode[]
  referrals              Referral[]
  ai_insights            AiInsight[]
  expense_categories     ExpenseCategory[]
  expenses               Expense[]
  clinical_visits        ClinicalVisit[]
  treatment_plans        TreatmentPlan[]
  membership_plans       MembershipPlan[]
  membership_enrollments MembershipEnrollment[]
  membership_usages      MembershipBenefitUsage[]

  @@index([email])
  @@index([plan_id])
  @@map("clinics")
}

model Branch {
  id        String  @id @default(uuid()) @db.Uuid
  clinic_id String  @db.Uuid
  name      String  @db.VarChar(255)
  phone     String? @db.VarChar(50)
  address   String? @db.VarChar(500)
  city      String? @db.VarChar(100)
  state     String? @db.VarChar(100)
  country   String? @db.VarChar(100)
  pincode   String? @db.VarChar(10)

  // Location (for Google Maps directions / WhatsApp "Get Directions" button)
  latitude  Float?
  longitude Float?
  map_url   String? @db.VarChar(500) // Google Maps directions URL

  // Online booking URL — custom URL set by clinic, or fallback to smartdentaldesk.com/booking/{clinicId}/{branchId}
  book_now_url String? @db.VarChar(2000)

  // Configurable scheduling settings (admin-managed per branch)
  working_start_time    String? @db.VarChar(5) // HH:mm e.g. "09:00"
  working_end_time      String? @db.VarChar(5) // HH:mm e.g. "18:00"
  lunch_start_time      String? @db.VarChar(5) // HH:mm e.g. "13:00"
  lunch_end_time        String? @db.VarChar(5) // HH:mm e.g. "14:00"
  slot_duration         Int?    @default(15) // minutes: 15, 20, 30, 45, 60
  default_appt_duration Int?    @default(30) // default appointment length in minutes
  buffer_minutes        Int?    @default(0) // buffer gap between appointments
  advance_booking_days  Int?    @default(30) // how far ahead patients can book
  working_days          String? @db.VarChar(20) // comma-separated: "1,2,3,4,5,6" (1=Mon, 7=Sun)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinic           Clinic                  @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  users            User[]
  patients         Patient[]
  appointments     Appointment[]
  treatments       Treatment[]
  prescriptions    Prescription[]
  invoices         Invoice[]
  inventory_items  InventoryItem[]
  attachments      Attachment[]
  tooth_conditions PatientToothCondition[]
  expenses         Expense[]
  clinical_visits  ClinicalVisit[]
  treatment_plans  TreatmentPlan[]
  membership_enrollments MembershipEnrollment[]

  @@index([clinic_id])
  @@map("branches")
}

model Plan {
  id                         String   @id @default(uuid()) @db.Uuid
  name                       String   @unique @db.VarChar(100)
  price_monthly              Decimal  @db.Decimal(10, 2)
  max_branches               Int
  max_staff                  Int
  ai_quota                   Int      @default(0)
  max_patients_per_month     Int? // null = unlimited
  max_appointments_per_month Int? // null = unlimited
  razorpay_plan_id           String?  @db.VarChar(100)
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  clinics       Clinic[]
  plan_features PlanFeature[]

  @@map("plans")
}

model Feature {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  description String   @db.VarChar(500)
  created_at  DateTime @default(now())

  plan_features PlanFeature[]

  @@map("features")
}

model PlanFeature {
  id         String  @id @default(uuid()) @db.Uuid
  plan_id    String  @db.Uuid
  feature_id String  @db.Uuid
  is_enabled Boolean @default(true)

  plan    Plan    @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [feature_id], references: [id], onDelete: Cascade)

  @@unique([plan_id, feature_id])
  @@index([plan_id])
  @@index([feature_id])
  @@map("plan_features")
}

model SuperAdmin {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  name          String   @db.VarChar(255)
  status        String   @default("active") @db.VarChar(20)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("super_admins")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  clinic_id      String   @db.Uuid
  branch_id      String?  @db.Uuid
  name           String   @db.VarChar(255)
  email          String   @db.VarChar(255)
  phone          String?  @db.VarChar(20)
  password_hash  String   @db.VarChar(255)
  role           String   @db.VarChar(50)
  status         String   @default("active") @db.VarChar(20)
  email_verified Boolean  @default(false)
  phone_verified Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  clinic           Clinic                  @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch           Branch?                 @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  appointments     Appointment[]
  treatments       Treatment[]
  prescriptions    Prescription[]
  attachments      Attachment[]
  tooth_conditions PatientToothCondition[] @relation("ToothConditionDentist")
  ai_insights      AiInsight[]
  expenses         Expense[]
  clinical_visits  ClinicalVisit[]         @relation("VisitDentist")
  treatment_plans  TreatmentPlan[]         @relation("PlanDentist")

  @@unique([email, clinic_id])
  @@index([clinic_id])
  @@index([branch_id])
  @@index([email])
  @@map("users")
}

model Patient {
  id              String    @id @default(uuid()) @db.Uuid
  clinic_id       String    @db.Uuid
  branch_id       String    @db.Uuid
  first_name      String    @db.VarChar(100)
  last_name       String    @db.VarChar(100)
  phone           String    @db.VarChar(50)
  email           String?   @db.VarChar(255)
  gender          String    @db.VarChar(20)
  date_of_birth   DateTime? @db.Date
  age             Int?
  blood_group     String?   @db.VarChar(10)
  medical_history Json?     @default("{}")
  allergies       String?   @db.VarChar(1000)
  notes           String?   @db.Text
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  preferred_language String @default("en") @db.VarChar(5)

  clinic                   Clinic                          @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch                   Branch                          @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  appointments             Appointment[]
  treatments               Treatment[]
  prescriptions            Prescription[]
  invoices                 Invoice[]
  attachments              Attachment[]
  tooth_conditions         PatientToothCondition[]
  communication_messages   CommunicationMessage[]
  communication_preference PatientCommunicationPreference?
  feedback                 PatientFeedback[]
  referral_codes           PatientReferralCode[]           @relation("PatientReferralCodes")
  referrals_as_referrer    Referral[]                      @relation("ReferrerPatient")
  referrals_as_referred    Referral[]                      @relation("ReferredPatient")
  clinical_visits          ClinicalVisit[]
  treatment_plans          TreatmentPlan[]
  primary_memberships      MembershipEnrollment[]          @relation("MembershipPrimaryPatient")
  covered_memberships      MembershipEnrollmentMember[]    @relation("MembershipCoveredPatient")
  membership_usages        MembershipBenefitUsage[]        @relation("MembershipUsagePatient")

  @@index([clinic_id])
  @@index([branch_id])
  @@index([clinic_id, branch_id])
  @@index([phone])
  @@index([first_name, last_name])
  @@map("patients")
}

model Appointment {
  id                  String   @id @default(uuid()) @db.Uuid
  clinic_id           String   @db.Uuid
  branch_id           String   @db.Uuid
  patient_id          String   @db.Uuid
  dentist_id          String   @db.Uuid
  appointment_date    DateTime @db.Date
  start_time          String   @db.VarChar(5)
  end_time            String   @db.VarChar(5)
  status              String   @default("scheduled") @db.VarChar(20)
  notes               String?  @db.Text
  recurrence_group_id String?  @db.Uuid
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  clinic          Clinic          @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch          Branch          @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  patient         Patient         @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  dentist         User            @relation(fields: [dentist_id], references: [id], onDelete: Cascade)
  clinical_visits ClinicalVisit[]

  @@index([clinic_id])
  @@index([branch_id])
  @@index([patient_id])
  @@index([dentist_id])
  @@index([dentist_id, appointment_date])
  @@index([appointment_date])
  @@index([recurrence_group_id])
  @@map("appointments")
}

model Treatment {
  id                String   @id @default(uuid()) @db.Uuid
  clinic_id         String   @db.Uuid
  branch_id         String   @db.Uuid
  patient_id        String   @db.Uuid
  dentist_id        String   @db.Uuid
  clinical_visit_id String?  @db.Uuid
  treatment_plan_id String?  @db.Uuid
  tooth_number      String?  @db.VarChar(100)
  diagnosis         String   @db.VarChar(500)
  procedure         String   @db.VarChar(500)
  status            String   @default("planned") @db.VarChar(20)
  cost              Decimal  @db.Decimal(10, 2)
  notes             String?  @db.Text
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  clinic         Clinic              @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch         Branch              @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  patient        Patient             @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  dentist        User                @relation(fields: [dentist_id], references: [id], onDelete: Cascade)
  clinical_visit ClinicalVisit?      @relation(fields: [clinical_visit_id], references: [id], onDelete: SetNull)
  treatment_plan TreatmentPlan?      @relation(fields: [treatment_plan_id], references: [id], onDelete: SetNull)
  plan_items     TreatmentPlanItem[]
  invoice_items  InvoiceItem[]
  membership_usages MembershipBenefitUsage[]

  @@index([clinic_id])
  @@index([branch_id])
  @@index([patient_id])
  @@index([dentist_id])
  @@index([clinical_visit_id])
  @@index([treatment_plan_id])
  @@index([patient_id, tooth_number])
  @@map("treatments")
}

model Prescription {
  id                String   @id @default(uuid()) @db.Uuid
  clinic_id         String   @db.Uuid
  branch_id         String   @db.Uuid
  patient_id        String   @db.Uuid
  dentist_id        String   @db.Uuid
  clinical_visit_id String?  @db.Uuid // Optional link to consultation
  diagnosis         String   @db.VarChar(500)
  instructions      String?  @db.Text
  created_at        DateTime @default(now())

  clinic         Clinic              @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch         Branch              @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  patient        Patient             @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  dentist        User                @relation(fields: [dentist_id], references: [id], onDelete: Cascade)
  clinical_visit ClinicalVisit?      @relation(fields: [clinical_visit_id], references: [id], onDelete: SetNull)
  items          PrescriptionItem[]

  @@index([clinic_id])
  @@index([patient_id])
  @@index([dentist_id])
  @@index([clinical_visit_id])
  @@map("prescriptions")
}

model PrescriptionItem {
  id              String  @id @default(uuid()) @db.Uuid
  prescription_id String  @db.Uuid
  medicine_name   String  @db.VarChar(255)
  dosage          String  @db.VarChar(100)
  frequency       String  @db.VarChar(100)
  duration        String  @db.VarChar(100)
  morning         Int     @default(0)
  afternoon       Int     @default(0)
  evening         Int     @default(0)
  night           Int     @default(0)
  notes           String? @db.Text

  prescription Prescription @relation(fields: [prescription_id], references: [id], onDelete: Cascade)

  @@index([prescription_id])
  @@map("prescription_items")
}

model Invoice {
  id              String   @id @default(uuid()) @db.Uuid
  clinic_id       String   @db.Uuid
  branch_id       String   @db.Uuid
  patient_id      String   @db.Uuid
  invoice_number  String   @db.VarChar(50)
  total_amount    Decimal  @db.Decimal(10, 2)
  tax_amount      Decimal  @default(0) @db.Decimal(10, 2)
  discount_amount Decimal  @default(0) @db.Decimal(10, 2)
  net_amount      Decimal  @db.Decimal(10, 2)
  gst_number      String?  @db.VarChar(20)
  tax_breakdown   Json?
  status          String   @default("pending") @db.VarChar(20) // pending | partially_paid | paid
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  clinic           Clinic           @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch           Branch           @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  patient          Patient          @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  items            InvoiceItem[]
  payments         Payment[]
  installment_plan InstallmentPlan?
  membership_usages MembershipBenefitUsage[]

  @@unique([clinic_id, invoice_number])
  @@index([clinic_id])
  @@index([branch_id])
  @@index([patient_id])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id           String  @id @default(uuid()) @db.Uuid
  invoice_id   String  @db.Uuid
  treatment_id String? @db.Uuid
  item_type    String  @default("service") @db.VarChar(20) // treatment | service | pharmacy
  description  String  @db.VarChar(500)
  quantity     Int     @default(1)
  unit_price   Decimal @db.Decimal(10, 2)
  total_price  Decimal @db.Decimal(10, 2)

  invoice   Invoice    @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  treatment Treatment? @relation(fields: [treatment_id], references: [id], onDelete: SetNull)

  @@index([invoice_id])
  @@index([treatment_id])
  @@map("invoice_items")
}

model Payment {
  id                  String   @id @default(uuid()) @db.Uuid
  invoice_id          String   @db.Uuid
  installment_item_id String?  @db.Uuid
  method              String   @db.VarChar(20)
  amount              Decimal  @db.Decimal(10, 2)
  notes               String?  @db.VarChar(500)
  paid_at             DateTime @default(now())

  invoice          Invoice          @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  installment_item InstallmentItem? @relation(fields: [installment_item_id], references: [id], onDelete: SetNull)

  @@index([invoice_id])
  @@index([installment_item_id])
  @@map("payments")
}

model InstallmentPlan {
  id               String   @id @default(uuid()) @db.Uuid
  invoice_id       String   @unique @db.Uuid
  total_amount     Decimal  @db.Decimal(10, 2)
  num_installments Int
  notes            String?  @db.Text
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  invoice Invoice           @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  items   InstallmentItem[]

  @@index([invoice_id])
  @@map("installment_plans")
}

model InstallmentItem {
  id                  String    @id @default(uuid()) @db.Uuid
  installment_plan_id String    @db.Uuid
  installment_number  Int
  amount              Decimal   @db.Decimal(10, 2)
  due_date            DateTime  @db.Date
  status              String    @default("pending") @db.VarChar(20) // pending | paid | overdue
  paid_at             DateTime?
  created_at          DateTime  @default(now())

  plan     InstallmentPlan @relation(fields: [installment_plan_id], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([installment_plan_id])
  @@map("installment_items")
}

model MembershipPlan {
  id                   String   @id @default(uuid()) @db.Uuid
  clinic_id            String   @db.Uuid
  code                 String?  @db.VarChar(50)
  name                 String   @db.VarChar(150)
  description          String?  @db.Text
  category             String?  @db.VarChar(50)
  price                Decimal  @default(0) @db.Decimal(10, 2)
  duration_months      Int      @default(12)
  covered_members_limit Int     @default(1)
  grace_period_days    Int      @default(0)
  is_active            Boolean  @default(true)
  terms_and_conditions String?  @db.Text
  metadata             Json?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  clinic      Clinic                 @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  benefits    MembershipBenefit[]
  enrollments MembershipEnrollment[]

  @@unique([clinic_id, name])
  @@unique([clinic_id, code])
  @@index([clinic_id])
  @@index([clinic_id, is_active])
  @@map("membership_plans")
}

model MembershipBenefit {
  id                  String   @id @default(uuid()) @db.Uuid
  membership_plan_id  String   @db.Uuid
  title               String   @db.VarChar(150)
  description         String?  @db.Text
  benefit_type        String   @db.VarChar(30) // included_service | discount_percentage | discount_flat | credit
  treatment_label     String?  @db.VarChar(150)
  coverage_scope      String   @default("shared") @db.VarChar(20) // shared | per_member
  included_quantity   Int?
  discount_percentage Decimal? @db.Decimal(5, 2)
  discount_amount     Decimal? @db.Decimal(10, 2)
  credit_amount       Decimal? @db.Decimal(10, 2)
  display_order       Int      @default(0)
  is_active           Boolean  @default(true)
  metadata            Json?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  membership_plan MembershipPlan          @relation(fields: [membership_plan_id], references: [id], onDelete: Cascade)
  usages          MembershipBenefitUsage[]

  @@index([membership_plan_id])
  @@index([membership_plan_id, is_active])
  @@map("membership_benefits")
}

model MembershipEnrollment {
  id                 String   @id @default(uuid()) @db.Uuid
  clinic_id          String   @db.Uuid
  branch_id          String   @db.Uuid
  membership_plan_id String   @db.Uuid
  primary_patient_id String   @db.Uuid
  enrollment_number  String   @db.VarChar(50)
  status             String   @default("active") @db.VarChar(20) // active | expired | cancelled | paused
  start_date         DateTime @db.Date
  end_date           DateTime @db.Date
  amount_paid        Decimal  @default(0) @db.Decimal(10, 2)
  notes              String?  @db.Text
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  clinic          Clinic                     @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch          Branch                     @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  membership_plan MembershipPlan             @relation(fields: [membership_plan_id], references: [id], onDelete: Cascade)
  primary_patient Patient                    @relation("MembershipPrimaryPatient", fields: [primary_patient_id], references: [id], onDelete: Cascade)
  members         MembershipEnrollmentMember[]
  usages          MembershipBenefitUsage[]

  @@unique([clinic_id, enrollment_number])
  @@index([clinic_id])
  @@index([branch_id])
  @@index([membership_plan_id])
  @@index([primary_patient_id])
  @@index([clinic_id, status])
  @@map("membership_enrollments")
}

model MembershipEnrollmentMember {
  id                       String   @id @default(uuid()) @db.Uuid
  membership_enrollment_id String   @db.Uuid
  patient_id               String   @db.Uuid
  relation_label           String?  @db.VarChar(50)
  is_primary               Boolean  @default(false)
  created_at               DateTime @default(now())

  enrollment MembershipEnrollment   @relation(fields: [membership_enrollment_id], references: [id], onDelete: Cascade)
  patient    Patient                @relation("MembershipCoveredPatient", fields: [patient_id], references: [id], onDelete: Cascade)

  @@unique([membership_enrollment_id, patient_id])
  @@index([membership_enrollment_id])
  @@index([patient_id])
  @@map("membership_enrollment_members")
}

model MembershipBenefitUsage {
  id                       String   @id @default(uuid()) @db.Uuid
  clinic_id                String   @db.Uuid
  membership_enrollment_id String   @db.Uuid
  membership_benefit_id    String   @db.Uuid
  patient_id               String   @db.Uuid
  treatment_id             String?  @db.Uuid
  invoice_id               String?  @db.Uuid
  quantity_used            Int      @default(1)
  discount_applied         Decimal? @db.Decimal(10, 2)
  notes                    String?  @db.Text
  used_on                  DateTime @default(now())
  created_at               DateTime @default(now())

  clinic     Clinic                @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  enrollment MembershipEnrollment  @relation(fields: [membership_enrollment_id], references: [id], onDelete: Cascade)
  benefit    MembershipBenefit     @relation(fields: [membership_benefit_id], references: [id], onDelete: Cascade)
  patient    Patient               @relation("MembershipUsagePatient", fields: [patient_id], references: [id], onDelete: Cascade)
  treatment  Treatment?            @relation(fields: [treatment_id], references: [id], onDelete: SetNull)
  invoice    Invoice?              @relation(fields: [invoice_id], references: [id], onDelete: SetNull)

  @@index([clinic_id])
  @@index([membership_enrollment_id])
  @@index([membership_benefit_id])
  @@index([patient_id])
  @@index([treatment_id])
  @@index([invoice_id])
  @@index([used_on])
  @@map("membership_benefit_usages")
}

model InventoryItem {
  id            String  @id @default(uuid()) @db.Uuid
  clinic_id     String  @db.Uuid
  branch_id     String  @db.Uuid
  name          String  @db.VarChar(255)
  category      String? @db.VarChar(100)
  quantity      Int     @default(0)
  unit          String  @db.VarChar(50)
  reorder_level Int     @default(0)
  supplier      String? @db.VarChar(255)

  // === Packaging / UOM ===
  // How you purchase (outermost unit)
  purchase_unit  String?  @db.VarChar(50) // "box", "bottle", "pack", "carton"
  purchase_price Decimal? @db.Decimal(10, 2) // price for 1 purchase_unit

  // Intermediate packaging (optional, e.g. strips inside box)
  pack_unit          String? @db.VarChar(50) // "strip", "sachet", "blister"
  packs_per_purchase Int? // e.g. 10 strips per box

  // Dispensing unit = existing `unit` field (tablet, ml, capsule, etc.)
  units_per_pack Int? // e.g. 10 tablets per strip
  // for 2-level: tablets per bottle

  // Derived / stored
  units_in_purchase Int? // total dispensing units per purchase (auto)
  cost_price        Decimal? @db.Decimal(10, 2) // cost per dispensing unit (auto = purchase_price / units_in_purchase)
  selling_price     Decimal? @db.Decimal(10, 2) // selling price per dispensing unit
  markup_percent    Decimal? @db.Decimal(5, 2) // optional markup % (auto-fills selling_price)

  // Legacy (kept for backwards compat)
  price_per_unit Decimal? @db.Decimal(10, 2)
  price_per_box  Decimal? @db.Decimal(10, 2)
  units_per_box  Int?

  expiry_date  DateTime?
  batch_number String?   @db.VarChar(100)
  location     String?   @db.VarChar(100)
  notes        String?   @db.Text
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branch_id], references: [id], onDelete: Cascade)

  @@index([clinic_id])
  @@index([branch_id])
  @@index([clinic_id, branch_id])
  @@index([name])
  @@map("inventory_items")
}

