generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(255)
  email      String   @db.VarChar(255)
  phone      String?  @db.VarChar(50)
  address    String?  @db.VarChar(500)
  city       String?  @db.VarChar(100)
  state      String?  @db.VarChar(100)
  country    String?  @db.VarChar(100)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users    User[]
  branches Branch[]

  @@index([email])
  @@map("clinics")
}

model Branch {
  id         String   @id @default(uuid()) @db.Uuid
  clinic_id  String   @db.Uuid
  name       String   @db.VarChar(255)
  phone      String?  @db.VarChar(50)
  address    String?  @db.VarChar(500)
  city       String?  @db.VarChar(100)
  state      String?  @db.VarChar(100)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  users  User[]

  @@index([clinic_id])
  @@map("branches")
}

model Plan {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @unique @db.VarChar(100)
  price_monthly Decimal  @db.Decimal(10, 2)
  max_branches  Int
  max_staff     Int
  ai_quota      Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  plan_features PlanFeature[]

  @@map("plans")
}

model Feature {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  description String   @db.VarChar(500)
  created_at  DateTime @default(now())

  plan_features PlanFeature[]

  @@map("features")
}

model PlanFeature {
  id         String  @id @default(uuid()) @db.Uuid
  plan_id    String  @db.Uuid
  feature_id String  @db.Uuid
  is_enabled Boolean @default(true)

  plan    Plan    @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [feature_id], references: [id], onDelete: Cascade)

  @@unique([plan_id, feature_id])
  @@index([plan_id])
  @@index([feature_id])
  @@map("plan_features")
}

model SuperAdmin {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  name          String   @db.VarChar(255)
  status        String   @default("active") @db.VarChar(20)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("super_admins")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  clinic_id     String   @db.Uuid
  branch_id     String?  @db.Uuid
  name          String   @db.VarChar(255)
  email         String   @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  role          String   @db.VarChar(50)
  status        String   @default("active") @db.VarChar(20)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  clinic Clinic  @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branch_id], references: [id], onDelete: SetNull)

  @@unique([email, clinic_id])
  @@index([clinic_id])
  @@index([branch_id])
  @@index([email])
  @@map("users")
}
