generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String    @db.VarChar(255)
  email               String    @db.VarChar(255)
  phone               String?   @db.VarChar(50)
  address             String?   @db.VarChar(500)
  city                String?   @db.VarChar(100)
  state               String?   @db.VarChar(100)
  country             String?   @db.VarChar(100)
  pincode             String?   @db.VarChar(10)
  plan_id             String?   @db.Uuid
  subscription_status String    @default("trial") @db.VarChar(20)
  subscription_id     String?   @db.VarChar(100)
  billing_cycle       String    @default("monthly") @db.VarChar(10) // monthly | yearly
  trial_ends_at       DateTime?
  // Next Razorpay subscription charge time. Populated from
  // subscription.activated / subscription.charged webhooks (using the
  // Razorpay `current_end` field). Used by the daily renewal-reminder cron
  // so we don't have to call Razorpay for every clinic. NULL until the
  // first subscription event arrives (trial clinics or unconfigured).
  next_billing_at     DateTime?
  is_complimentary    Boolean   @default(false)
  has_own_waba        Boolean   @default(false) // true = clinic brings their own WhatsApp Business Account (no platform WA billing)
  logo_url            String?   @db.Text
  currency_code              String    @default("INR") @db.VarChar(10)
  default_phone_country      String    @default("in") @db.VarChar(10)
  ai_usage_count      Int       @default(0)
  ai_quota_override   Int? // per-clinic AI quota override (null = use global/plan default)
  // Per-clinic monthly limit overrides (set by super admin; null = use plan default)
  custom_patient_limit      Int?
  custom_appointment_limit  Int?
  custom_invoice_limit      Int?
  custom_treatment_limit    Int?
  custom_prescription_limit Int?
  custom_consultation_limit Int?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  ai_settings                ClinicAiSettings?
  ai_usage_records           AiUsageRecord[]
  ai_overage_charges         AiOverageCharge[]
  ai_quota_approval_requests AiQuotaApprovalRequest[]
  plan                       Plan?                        @relation(fields: [plan_id], references: [id], onDelete: SetNull)
  users                      User[]
  branches                   Branch[]
  patients                   Patient[]
  appointments               Appointment[]
  treatments                 Treatment[]
  prescriptions              Prescription[]
  invoices                   Invoice[]
  inventory_items            InventoryItem[]
  attachments                Attachment[]
  tooth_conditions           PatientToothCondition[]
  notifications              Notification[]
  communication_messages     CommunicationMessage[]
  message_templates          MessageTemplate[]
  communication_settings     ClinicCommunicationSettings?
  campaigns                  Campaign[]
  automation_rules           AutomationRule[]
  clinic_events              ClinicEvent[]
  patient_feedback           PatientFeedback[]
  referral_codes             PatientReferralCode[]
  referrals                  Referral[]
  ai_insights                AiInsight[]
  expense_categories         ExpenseCategory[]
  expenses                   Expense[]
  clinical_visits            ClinicalVisit[]
  treatment_plans            TreatmentPlan[]
  membership_plans           MembershipPlan[]
  membership_enrollments     MembershipEnrollment[]
  membership_usages          MembershipBenefitUsage[]
  usage_counters             ClinicUsageCounter[]
  consent_templates          ConsentTemplate[]
  patient_consents           PatientConsent[]

  // ─── DISABLED: Google Business Profile review auto-reply feature ───
  // Re-enable these relations together with the GoogleBusinessConnection /
  // GoogleReviewSettings / GoogleReview models below once Google grants
  // Business Profile API access.
  //
  // google_business_connection GoogleBusinessConnection?
  // google_review_settings     GoogleReviewSettings?
  // google_reviews             GoogleReview[]

  platform_invoices PlatformInvoice[]

  @@index([email])
  @@index([plan_id])
  @@map("clinics")
}

model Branch {
  id        String  @id @default(uuid()) @db.Uuid
  clinic_id String  @db.Uuid
  name      String  @db.VarChar(255)
  phone     String? @db.VarChar(50)
  address   String? @db.VarChar(500)
  city      String? @db.VarChar(100)
  state     String? @db.VarChar(100)
  country   String? @db.VarChar(100)
  pincode   String? @db.VarChar(10)

  // Location (for Google Maps directions / WhatsApp "Get Directions" button)
  latitude  Float?
  longitude Float?
  map_url   String? @db.VarChar(500) // Google Maps directions URL

  // Online booking URL — custom URL set by clinic, or fallback to smartdentaldesk.com/booking/{clinicId}/{branchId}
  book_now_url String? @db.VarChar(2000)

  // Configurable scheduling settings (admin-managed per branch)
  working_start_time    String? @db.VarChar(5) // HH:mm e.g. "09:00"
  working_end_time      String? @db.VarChar(5) // HH:mm e.g. "18:00"
  lunch_start_time      String? @db.VarChar(5) // HH:mm e.g. "13:00"
  lunch_end_time        String? @db.VarChar(5) // HH:mm e.g. "14:00"
  slot_duration         Int?    @default(15) // minutes: 15, 20, 30, 45, 60
  default_appt_duration Int?    @default(30) // default appointment length in minutes
  buffer_minutes        Int?    @default(0) // buffer gap between appointments
  advance_booking_days  Int?    @default(30) // how far ahead patients can book
  working_days          String? @db.VarChar(20) // comma-separated: "1,2,3,4,5,6" (1=Mon, 7=Sun)

  // Per-branch custom prescription notepad template — clinic uploads scan of
  // their pre-printed pad and defines zones for where each field gets printed.
  // enabled=false → use the default Smart Dental Desk layout.
  prescription_template_url     String? @db.VarChar(500)
  prescription_template_config  Json?
  prescription_template_enabled Boolean @default(false)

  // Self-registration QR code — patients scan this to register themselves.
  qr_code_token        String?   @db.VarChar(20)
  qr_code_enabled      Boolean   @default(false)
  qr_code_generated_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinic                 Clinic                  @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  users                  User[]
  patients               Patient[]
  appointments           Appointment[]
  treatments             Treatment[]
  prescriptions          Prescription[]
  invoices               Invoice[]
  inventory_items        InventoryItem[]
  attachments            Attachment[]
  tooth_conditions       PatientToothCondition[]
  expenses               Expense[]
  clinical_visits        ClinicalVisit[]
  treatment_plans        TreatmentPlan[]
  membership_enrollments MembershipEnrollment[]
  patient_consents       PatientConsent[]

  @@unique([qr_code_token])
  @@index([clinic_id])
  @@map("branches")
}

model Plan {
  id                             String   @id @default(uuid()) @db.Uuid
  name                           String   @unique @db.VarChar(100)
  price_monthly                  Decimal  @db.Decimal(10, 2)
  price_yearly                   Decimal? @db.Decimal(10, 2) // null for free plan
  max_branches                   Int
  max_staff                      Int
  ai_quota                       Int      @default(0) // base AI requests included per cycle (0 = unlimited)
  ai_overage_cap                 Int      @default(0) // max requests allowed during a cycle when clinic enables overage (0 = no overage)
  max_patients_per_month         Int? // null = unlimited
  max_appointments_per_month     Int? // null = unlimited
  max_invoices_per_month         Int? // null = unlimited
  max_treatments_per_month       Int? // null = unlimited
  max_prescriptions_per_month    Int? // null = unlimited
  max_consultations_per_month    Int? // null = unlimited
  razorpay_plan_id               String?  @db.VarChar(100)
  razorpay_plan_id_yearly        String?  @db.VarChar(100)
  whatsapp_included_monthly      Int? // messages/month included in the plan (null = unlimited / BYO WABA)
  whatsapp_hard_limit_monthly    Int? // hard cap that blocks further WA sends (null = no block, overage allowed)
  allow_whatsapp_overage_billing Boolean  @default(false) // true = track overage for billing via payment link
  created_at                     DateTime @default(now())
  updated_at                     DateTime @updatedAt

  clinics           Clinic[]
  plan_features     PlanFeature[]
  platform_invoices PlatformInvoice[]

  @@map("plans")
}

model Feature {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  description String   @db.VarChar(500)
  created_at  DateTime @default(now())

  plan_features PlanFeature[]

  @@map("features")
}

model PlanFeature {
  id         String  @id @default(uuid()) @db.Uuid
  plan_id    String  @db.Uuid
  feature_id String  @db.Uuid
  is_enabled Boolean @default(true)

  plan    Plan    @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [feature_id], references: [id], onDelete: Cascade)

  @@unique([plan_id, feature_id])
  @@index([plan_id])
  @@index([feature_id])
  @@map("plan_features")
}

/// Per-clinic per-month counters for messaging usage.
/// period_start is the first day of the billing month at 00:00 UTC.
model ClinicUsageCounter {
  id            String   @id @default(uuid()) @db.Uuid
  clinic_id     String   @db.Uuid
  period_start  DateTime @db.Date // first day of the month
  whatsapp_sent Int      @default(0)
  sms_sent      Int      @default(0)
  email_sent    Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)

  @@unique([clinic_id, period_start])
  @@index([clinic_id])
  @@index([period_start])
  @@map("clinic_usage_counters")
}

model SuperAdmin {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  name          String   @db.VarChar(255)
  status        String   @default("active") @db.VarChar(20)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("super_admins")
}

model User {
  id                String   @id @default(uuid()) @db.Uuid
  clinic_id         String   @db.Uuid
  branch_id         String?  @db.Uuid
  name              String   @db.VarChar(255)
  email             String   @db.VarChar(255)
  phone             String?  @db.VarChar(20)
  password_hash     String   @db.VarChar(255)
  role              String   @db.VarChar(50)
  status            String   @default("active") @db.VarChar(20)
  email_verified    Boolean  @default(false)
  phone_verified    Boolean  @default(false)
  // Doctor-specific (optional). Printed on prescription PDFs:
  // signature_url is an S3 key for an uploaded signature image.
  is_doctor         Boolean  @default(false)
  license_number    String?  @db.VarChar(100)
  signature_url     String?  @db.VarChar(500)
  // S3 key for the staff member's profile photo (private; served via presigned URL).
  profile_photo_url String?  @db.VarChar(500)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  clinic                    Clinic                  @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch                    Branch?                 @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  appointments              Appointment[]
  treatments                Treatment[]
  prescriptions             Prescription[]
  attachments               Attachment[]
  tooth_conditions          PatientToothCondition[] @relation("ToothConditionDentist")
  ai_insights               AiInsight[]
  ai_usage_records          AiUsageRecord[]
  expenses                  Expense[]
  clinical_visits           ClinicalVisit[]         @relation("VisitDentist")
  treatment_plans           TreatmentPlan[]         @relation("PlanDentist")
  invoices_as_dentist       Invoice[]               @relation("InvoiceDentist")
  invoices_created          Invoice[]               @relation("InvoiceCreatedBy")
  consents_signed           PatientConsent[]        @relation("ConsentSignedByStaff")
  consents_witnessed        PatientConsent[]        @relation("ConsentWitnessStaff")
  consent_templates_created ConsentTemplate[]       @relation("ConsentTemplateCreatedBy")
  refunds_issued            Refund[]                @relation("RefundIssuedBy")

  @@unique([email, clinic_id])
  @@index([clinic_id])
  @@index([branch_id])
  @@index([email])
  @@map("users")
}

model Patient {
  id                String    @id @default(uuid()) @db.Uuid
  clinic_id         String    @db.Uuid
  branch_id         String    @db.Uuid
  first_name        String    @db.VarChar(100)
  last_name         String    @db.VarChar(100)
  phone             String    @db.VarChar(50)
  email             String?   @db.VarChar(255)
  gender            String    @db.VarChar(20)
  date_of_birth     DateTime? @db.Date
  age               Int?
  blood_group       String?   @db.VarChar(10)
  medical_history   Json?     @default("{}")
  allergies         String?   @db.VarChar(1000)
  notes             String?   @db.Text
  // S3 key for the patient's profile photo (private; served via presigned URL).
  profile_photo_url String?   @db.VarChar(500)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  preferred_language String @default("en") @db.VarChar(5)

  clinic                   Clinic                          @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch                   Branch                          @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  appointments             Appointment[]
  treatments               Treatment[]
  prescriptions            Prescription[]
  invoices                 Invoice[]
  attachments              Attachment[]
  tooth_conditions         PatientToothCondition[]
  communication_messages   CommunicationMessage[]
  communication_preference PatientCommunicationPreference?
  feedback                 PatientFeedback[]
  referral_codes           PatientReferralCode[]           @relation("PatientReferralCodes")
  referrals_as_referrer    Referral[]                      @relation("ReferrerPatient")
  referrals_as_referred    Referral[]                      @relation("ReferredPatient")
  clinical_visits          ClinicalVisit[]
  treatment_plans          TreatmentPlan[]
  primary_memberships      MembershipEnrollment[]          @relation("MembershipPrimaryPatient")
  covered_memberships      MembershipEnrollmentMember[]    @relation("MembershipCoveredPatient")
  membership_usages        MembershipBenefitUsage[]        @relation("MembershipUsagePatient")
  consents                 PatientConsent[]

  @@index([clinic_id])
  @@index([branch_id])
  @@index([clinic_id, branch_id])
  @@index([phone])
  @@index([first_name, last_name])
  @@map("patients")
}

model Appointment {
  id                  String   @id @default(uuid()) @db.Uuid
  clinic_id           String   @db.Uuid
  branch_id           String   @db.Uuid
  patient_id          String   @db.Uuid
  dentist_id          String   @db.Uuid
  appointment_date    DateTime @db.Date
  start_time          String   @db.VarChar(5)
  end_time            String   @db.VarChar(5)
  status              String   @default("scheduled") @db.VarChar(20)
  notes               String?  @db.Text
  recurrence_group_id String?  @db.Uuid
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  clinic          Clinic           @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch          Branch           @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  patient         Patient          @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  dentist         User             @relation(fields: [dentist_id], references: [id], onDelete: Cascade)
  clinical_visits ClinicalVisit[]
  consents        PatientConsent[]

  @@index([clinic_id])
  @@index([branch_id])
  @@index([patient_id])
  @@index([dentist_id])
  @@index([dentist_id, appointment_date])
  @@index([appointment_date])
  @@index([recurrence_group_id])
  @@map("appointments")
}

model Treatment {
  id                String   @id @default(uuid()) @db.Uuid
  clinic_id         String   @db.Uuid
  branch_id         String   @db.Uuid
  patient_id        String   @db.Uuid
  dentist_id        String   @db.Uuid
  clinical_visit_id String?  @db.Uuid
  treatment_plan_id String?  @db.Uuid
  tooth_number      String?  @db.VarChar(100)
  diagnosis         String   @db.VarChar(500)
  procedure         String   @db.VarChar(500)
  status            String   @default("planned") @db.VarChar(20)
  cost              Decimal  @db.Decimal(10, 2)
  notes             String?  @db.Text
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  clinic            Clinic                   @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch            Branch                   @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  patient           Patient                  @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  dentist           User                     @relation(fields: [dentist_id], references: [id], onDelete: Cascade)
  clinical_visit    ClinicalVisit?           @relation(fields: [clinical_visit_id], references: [id], onDelete: SetNull)
  treatment_plan    TreatmentPlan?           @relation(fields: [treatment_plan_id], references: [id], onDelete: SetNull)
  plan_items        TreatmentPlanItem[]
  invoice_items     InvoiceItem[]
  membership_usages MembershipBenefitUsage[]
  consents          PatientConsent[]

  @@index([clinic_id])
  @@index([branch_id])
  @@index([patient_id])
  @@index([dentist_id])
  @@index([clinical_visit_id])
  @@index([treatment_plan_id])
  @@index([patient_id, tooth_number])
  @@map("treatments")
}

model Prescription {
  id                        String   @id @default(uuid()) @db.Uuid
  clinic_id                 String   @db.Uuid
  branch_id                 String   @db.Uuid
  patient_id                String   @db.Uuid
  dentist_id                String   @db.Uuid
  clinical_visit_id         String?  @db.Uuid // Optional link to consultation
  // Frozen-at-issue clinical context. We snapshot these on the prescription
  // so it stays a stable, printable record even if the linked ClinicalVisit
  // is later edited.
  chief_complaint           String?  @db.Text
  past_dental_history       String?  @db.Text
  allergies_medical_history String?  @db.Text
  diagnosis                 String   @db.VarChar(500)
  instructions              String?  @db.Text
  // AI-generated safety fields. Optional — populated when the prescription was
  // produced or seeded by the AI assistant; rendered on the printable Rx so the
  // patient leaves with the same safety guidance the dentist saw.
  interactions                String?  @db.Text
  dietary_advice              String?  @db.Text
  post_procedure_instructions String?  @db.Text
  follow_up                   String?  @db.Text
  created_at                DateTime @default(now())

  clinic         Clinic             @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch         Branch             @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  patient        Patient            @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  dentist        User               @relation(fields: [dentist_id], references: [id], onDelete: Cascade)
  clinical_visit ClinicalVisit?     @relation(fields: [clinical_visit_id], references: [id], onDelete: SetNull)
  items          PrescriptionItem[]

  @@index([clinic_id])
  @@index([patient_id])
  @@index([dentist_id])
  @@index([clinical_visit_id])
  @@map("prescriptions")
}

model PrescriptionItem {
  id              String  @id @default(uuid()) @db.Uuid
  prescription_id String  @db.Uuid
  medicine_name   String  @db.VarChar(255)
  dosage          String  @db.VarChar(100)
  frequency       String  @db.VarChar(100)
  duration        String  @db.VarChar(100)
  morning         Int     @default(0)
  afternoon       Int     @default(0)
  evening         Int     @default(0)
  night           Int     @default(0)
  notes           String? @db.Text
  // AI-generated safety fields. Stored on the item so per-medicine context
  // (route, why prescribed, patient-facing warnings) prints alongside the row.
  route           String? @db.VarChar(50)
  purpose         String? @db.VarChar(255)
  warnings        String? @db.Text
  // Inventory linkage — set when the medicine maps to an in-stock item so the
  // dentist knows the Rx was filled from clinic inventory (vs. a fallback med).
  inventory_id    String? @db.Uuid

  prescription Prescription @relation(fields: [prescription_id], references: [id], onDelete: Cascade)

  @@index([prescription_id])
  @@map("prescription_items")
}

model Invoice {
  id                   String    @id @default(uuid()) @db.Uuid
  clinic_id            String    @db.Uuid
  branch_id            String    @db.Uuid
  patient_id           String    @db.Uuid
  dentist_id           String?   @db.Uuid
  // Staff member who generated the invoice — printed on the PDF as the
  // "Generated by" name + signature. Nullable for invoices created before
  // this feature shipped.
  created_by_user_id   String?   @db.Uuid
  // Date the treatment/service was actually rendered. Distinct from
  // `created_at` (when the invoice was entered) so we can honour cases
  // where a patient is treated in one month and billed in another. Optional
  // — when null, the PDF prints only the invoice date.
  treatment_date       DateTime? @db.Date
  invoice_number       String    @db.VarChar(50)
  total_amount         Decimal   @db.Decimal(10, 2)
  tax_amount           Decimal   @default(0) @db.Decimal(10, 2)
  discount_amount      Decimal   @default(0) @db.Decimal(10, 2)
  net_amount           Decimal   @db.Decimal(10, 2)
  gst_number           String?   @db.VarChar(20)
  tax_breakdown        Json?
  status               String    @default("pending") @db.VarChar(20) // pending | partially_paid | paid
  // Lifecycle status — orthogonal to the payment status above. Controls
  // which actions are allowed:
  //   draft     → editable, no payments yet, NOT visible to patient
  //   issued    → locked from edits; payments and refunds allowed
  //   cancelled → frozen for audit; no further actions allowed
  // Default `issued` for backwards compatibility (existing rows + flows
  // that don't yet know about the lifecycle still behave like before).
  lifecycle_status     String    @default("issued") @db.VarChar(20)
  // Audit fields for the issued/cancelled transitions. Useful for "who
  // marked this cancelled and why" lookups without needing a full audit log.
  issued_at            DateTime?
  issued_by_user_id    String?   @db.Uuid
  cancelled_at         DateTime?
  cancelled_by_user_id String?   @db.Uuid
  cancel_reason        String?   @db.VarChar(500)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  clinic            Clinic                   @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  branch            Branch                   @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  patient           Patient                  @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  dentist           User?                    @relation("InvoiceDentist", fields: [dentist_id], references: [id], onDelete: SetNull)
  created_by        User?                    @relation("InvoiceCreatedBy", fields: [created_by_user_id], references: [id], onDelete: SetNull)
  items             InvoiceItem[]
  payments          Payment[]
  refunds           Refund[]
  installment_plan  InstallmentPlan?
  membership_usages MembershipBenefitUsage[]

  @@unique([clinic_id, invoice_number])
  @@index([clinic_id])
  @@index([branch_id])
  @@index([patient_id])
  @@index([dentist_id])
  @@index([created_by_user_id])
  @@index([status])
  @@index([lifecycle_status])
  @@map("invoices")
}

model InvoiceItem {
  id           String  @id @default(uuid()) @db.Uuid
  invoice_id   String  @db.Uuid
  treatment_id String? @db.Uuid
  item_type    String  @default("service") @db.VarChar(20) // treatment | service | pharmacy
  description  String  @db.VarChar(500)
  quantity     Int     @default(1)
  unit_price   Decimal @db.Decimal(10, 2)
  total_price  Decimal @db.Decimal(10, 2)

  invoice   Invoice    @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  treatment Treatment? @relation(fields: [treatment_id], references: [id], onDelete: SetNull)

  @@index([invoice_id])
  @@index([treatment_id])
  @@map("invoice_items")
}

model Payment {
  id                  String   @id @default(uuid()) @db.Uuid
  invoice_id          String   @db.Uuid
  installment_item_id String?  @db.Uuid
  method              String   @db.VarChar(20)
  amount              Decimal  @db.Decimal(10, 2)
  notes               String?  @db.VarChar(500)
  paid_at             DateTime @default(now())

  invoice          Invoice          @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  installment_item InstallmentItem? @relation(fields: [installment_item_id], references: [id], onDelete: SetNull)
  refunds          Refund[]

  @@index([invoice_id])
  @@index([installment_item_id])
  @@map("payments")
}

// Refund recorded against an invoice. Modeled as a separate row (rather
// than a negative Payment) so the original payment record stays
// immutable for audit. A refund may optionally point at the specific
// payment it reverses; when null, it's treated as a generic credit
// against the invoice. Sum(payments) - sum(refunds) is the patient's
// net amount paid; this drives the lifecycle/payment status.
model Refund {
  id                  String   @id @default(uuid()) @db.Uuid
  clinic_id           String   @db.Uuid
  invoice_id          String   @db.Uuid
  payment_id          String?  @db.Uuid
  amount              Decimal  @db.Decimal(10, 2)
  method              String   @db.VarChar(20) // cash | card | upi | bank_transfer
  reason              String?  @db.VarChar(500)
  refunded_at         DateTime @default(now())
  refunded_by_user_id String?  @db.Uuid

  invoice     Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  payment     Payment? @relation(fields: [payment_id], references: [id], onDelete: SetNull)
  refunded_by User?    @relation("RefundIssuedBy", fields: [refunded_by_user_id], references: [id], onDelete: SetNull)

  @@index([clinic_id])
  @@index([invoice_id])
  @@index([payment_id])
  @@index([refunded_by_user_id])
  @@map("refunds")
}

