// ─── Automation Rules (Phase 3, Epic 10-11) ───

model AutomationRule {
  id          String   @id @default(uuid()) @db.Uuid
  clinic_id   String   @db.Uuid
  rule_type   String   @db.VarChar(50)
  // birthday_greeting | festival_greeting | post_treatment_care | no_show_followup
  // dormant_reactivation | treatment_plan_reminder | payment_reminder
  // feedback_collection | appointment_reminder
  is_enabled  Boolean  @default(true)
  channel     String   @default("whatsapp") @db.VarChar(20) // email | sms | whatsapp | preferred
  template_id String?  @db.Uuid
  config      Json? // rule-specific settings (delay_hours, dormancy_days, etc.)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  clinic   Clinic           @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  template MessageTemplate? @relation(fields: [template_id], references: [id], onDelete: SetNull)

  @@unique([clinic_id, rule_type])
  @@index([clinic_id])
  @@index([rule_type])
  @@map("automation_rules")
}

// ─── Clinic Events / Festival Calendar (Phase 3, Epic 10) ───

model ClinicEvent {
  id               String   @id @default(uuid()) @db.Uuid
  clinic_id        String?  @db.Uuid // null = system event (pre-seeded)
  event_name       String   @db.VarChar(255)
  event_date       DateTime @db.Date
  is_recurring     Boolean  @default(true) // repeat annually
