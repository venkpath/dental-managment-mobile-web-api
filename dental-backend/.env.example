PORT=3000
NODE_ENV=development

# PostgreSQL (Neon free tier: https://neon.tech)
DATABASE_URL="postgresql://neondb_owner:password@ep-shy-glitter-a4qx36tc-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://neondb_owner:password@ep-shy-glitter-a4qx36tc.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Redis (Upstash free tier: https://upstash.com)
REDIS_HOST=renewed-rooster-69094.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_TLS=true

# JWT
JWT_SECRET=change-me-to-a-strong-secret-in-production
JWT_EXPIRES_IN=1d

# CORS
CORS_ORIGIN=http://localhost:3001

# SMTP — global defaults, can be overridden per-clinic on Professional/Enterprise plans
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@yourclinic.com
SMTP_SECURE=false

# SMS (MSG91) — global defaults, can be overridden per-clinic on Professional/Enterprise plans
SMS_API_KEY=your_msg91_auth_key
SMS_SENDER_ID=DENTAL
SMS_ENTITY_ID=your_dlt_entity_id
# Fallback DLT Template ID — used when a message template has no dlt_template_id set.
# Set this to your registered DLT template ID so all SMS works out of the box.
# Once you register more DLT templates, set dlt_template_id on each template in the DB.
SMS_DEFAULT_DLT_TEMPLATE_ID=your_dlt_template_id
# DLT template body — the exact registered template text with {#var#} placeholders.
# Used as fallback when no DB template is linked. Change this env var to switch templates.
SMS_DLT_TEMPLATE_BODY="Your otp for {#var#} by grats it is {#var#}, otp valid for 10min, please don't share with any one,"
